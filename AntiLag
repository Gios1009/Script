local Workspace = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")

-- [[ CONFIGURATION ]] --
local BATCH_SIZE = 100 

-- [[ 1. FPS COUNTER UI ]] --
local function createFPSCounter()
	local LocalPlayer = Players.LocalPlayer
	local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
	
	-- Create the ScreenGui
	local fpsGui = Instance.new("ScreenGui")
	fpsGui.Name = "FPSCounterGui"
	fpsGui.ResetOnSpawn = false -- Keeps it on screen after you die
	fpsGui.Parent = PlayerGui
	
	-- Create the TextLabel
	local fpsLabel = Instance.new("TextLabel")
	fpsLabel.Size = UDim2.new(0, 80, 0, 25)
	fpsLabel.Position = UDim2.new(0.5, 0, 0, 5) -- Top middle, slightly offset from the very edge
	fpsLabel.AnchorPoint = Vector2.new(0.5, 0)
	fpsLabel.BackgroundTransparency = 0.5
	fpsLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	fpsLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
	fpsLabel.Font = Enum.Font.Code
	fpsLabel.TextSize = 16
	fpsLabel.Text = "FPS: --"
	fpsLabel.Parent = fpsGui
	
	-- Update the FPS text cleanly
	local lastUpdate = 0
	RunService.RenderStepped:Connect(function(deltaTime)
		local currentTime = os.clock()
		-- Update 4 times a second to prevent the numbers from becoming a blurry mess
		if currentTime - lastUpdate >= 0.25 then
			local fps = math.floor(1 / deltaTime)
			fpsLabel.Text = "FPS: " .. tostring(fps)
			
			-- Color coordinate based on performance
			if fps >= 50 then
				fpsLabel.TextColor3 = Color3.fromRGB(0, 255, 0) -- Green
			elseif fps >= 30 then
				fpsLabel.TextColor3 = Color3.fromRGB(255, 255, 0) -- Yellow
			else
				fpsLabel.TextColor3 = Color3.fromRGB(255, 0, 0) -- Red
			end
			
			lastUpdate = currentTime
		end
	end)
end

-- [[ 2. CORE OPTIMIZATION FUNCTION ]] --
local function optimizeObject(obj)
	if obj:IsA("Texture") or obj:IsA("Decal") or obj:IsA("SurfaceAppearance") then
		obj:Destroy()
		
	elseif obj:IsA("BasePart") then
		obj.Material = Enum.Material.SmoothPlastic
		obj.Reflectance = 0
		
	elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") then
		obj.Enabled = false
	end
end

-- [[ 3. LIGHTING AND FOG STRIPPER ]] --
local function optimizeLighting()
	Lighting.GlobalShadows = false
	Lighting.FogEnd = 9e9
	Lighting.ShadowSoftness = 0
	Lighting.Brightness = 2
	
	for _, effect in pairs(Lighting:GetChildren()) do
		if effect:IsA("PostEffect") or effect:IsA("Atmosphere") or effect:IsA("Sky") or effect:IsA("Clouds") then
			effect:Destroy()
		end
	end
	
	Lighting.Changed:Connect(function(property)
		if property == "FogEnd" and Lighting.FogEnd < 9e9 then
			Lighting.FogEnd = 9e9
		elseif property == "GlobalShadows" and Lighting.GlobalShadows == true then
			Lighting.GlobalShadows = false
		end
	end)
end

-- [[ 4. PACED WORKSPACE SCANNER ]] --
local function slowInitialScan()
	local descendants = Workspace:GetDescendants()
	
	for i, obj in ipairs(descendants) do
		pcall(optimizeObject, obj) 
		
		if i % BATCH_SIZE == 0 then
			RunService.Heartbeat:Wait()
		end
	end
	print("Optimization: Initial scan complete.")
end

-- [[ INITIALIZATION ]] --
print("Optimization: Script starting...")

-- Build the UI
createFPSCounter()

-- Clean the Lighting
optimizeLighting()

-- Hook up the listener for newly loaded objects
Workspace.DescendantAdded:Connect(function(obj)
	task.defer(function()
		pcall(optimizeObject, obj)
	end)
end)

-- Start the slow background scan
task.spawn(slowInitialScan)
