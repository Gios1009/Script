local Workspace = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")
local RunService = game:GetService("RunService")

-- [[ CONFIGURATION ]] --
-- Number of objects to process per frame. 
-- Lower = Slower process but zero lag spikes. Higher = Faster process but might stutter.
local BATCH_SIZE = 100 

-- [[ CORE OPTIMIZATION FUNCTION ]] --
local function optimizeObject(obj)
	-- 1. Remove Textures, Decals, and PBR Textures
	if obj:IsA("Texture") or obj:IsA("Decal") or obj:IsA("SurfaceAppearance") then
		obj:Destroy()
		
	-- 2. Simplify standard parts
	elseif obj:IsA("BasePart") then
		obj.Material = Enum.Material.SmoothPlastic
		obj.Reflectance = 0
		-- Note: MeshPart.TextureID is read-only at runtime in standard Roblox scripts.
		-- Setting the material to SmoothPlastic is the safest standard way to flatten their look.
		
	-- 3. Disable visual effects
	elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") then
		obj.Enabled = false
		-- We set Enabled = false instead of Destroy() just in case the game's core scripts rely on them existing.
	end
end

-- [[ LIGHTING AND FOG STRIPPER ]] --
local function optimizeLighting()
	Lighting.GlobalShadows = false
	Lighting.FogEnd = 9e9 -- Pushes fog so far away it effectively disappears
	Lighting.ShadowSoftness = 0
	Lighting.Brightness = 2 -- Keeps the map well-lit for visual clarity
	
	-- Destroy post-processing, skies, clouds, and atmosphere
	for _, effect in pairs(Lighting:GetChildren()) do
		if effect:IsA("PostEffect") or effect:IsA("Atmosphere") or effect:IsA("Sky") or effect:IsA("Clouds") then
			effect:Destroy()
		end
	end
	
	-- Keep an eye out for Lighting changes by the server and revert them
	Lighting.Changed:Connect(function(property)
		if property == "FogEnd" and Lighting.FogEnd < 9e9 then
			Lighting.FogEnd = 9e9
		elseif property == "GlobalShadows" and Lighting.GlobalShadows == true then
			Lighting.GlobalShadows = false
		end
	end)
end

-- [[ PACED WORKSPACE SCANNER ]] --
local function slowInitialScan()
	local descendants = Workspace:GetDescendants()
	
	for i, obj in ipairs(descendants) do
		-- pcall ensures that if a locked object is scanned, the script won't break
		pcall(optimizeObject, obj) 
		
		-- Yield the thread every BATCH_SIZE objects to prevent client freezing
		if i % BATCH_SIZE == 0 then
			RunService.Heartbeat:Wait()
		end
	end
	print("Optimization: Initial scan complete.")
end

-- [[ INITIALIZATION ]] --
print("Optimization: Script starting...")

-- 1. Clean the Lighting immediately
optimizeLighting()

-- 2. Hook up the listener for newly loaded objects
Workspace.DescendantAdded:Connect(function(obj)
	-- task.defer puts the function at the end of the execution queue for this frame.
	-- This prevents stuttering if StreamingEnabled suddenly loads a massive chunk of map at once.
	task.defer(function()
		pcall(optimizeObject, obj)
	end)
end)

-- 3. Start the slow background scan
task.spawn(slowInitialScan)
