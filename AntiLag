-- Place inside StarterPlayer -> StarterPlayerScripts

local Workspace = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")

-- [[ CONFIGURATION ]] --
-- Adjust these values to control the speed of the initial texture removal.
local BATCH_SIZE = 50      -- Number of objects to process before yielding
local YIELD_TIME = 0.05    -- How long to wait between batches (in seconds)

-- [[ 1. LIGHTING & TERRAIN OPTIMIZATION ]] --
local function OptimizeLightingAndTerrain()
	-- Disable Lighting overhead
	Lighting.GlobalShadows = false
	Lighting.FogEnd = 9e9
	Lighting.FogStart = 9e9
	Lighting.ShadowSoftness = 0
	Lighting.EnvironmentDiffuseScale = 0
	Lighting.EnvironmentSpecularScale = 0

	-- Destroy visual atmosphere/post-processing
	for _, obj in ipairs(Lighting:GetChildren()) do
		if obj:IsA("PostEffect") or obj:IsA("Atmosphere") or obj:IsA("Sky") or obj:IsA("Clouds") then
			obj:Destroy()
		end
	end

	-- Optimize Terrain
	local terrain = Workspace:FindFirstChildOfClass("Terrain")
	if terrain then
		terrain.WaterWaveSize = 0
		terrain.WaterWaveSpeed = 0
		terrain.WaterReflectance = 0
		terrain.WaterTransparency = 0
		terrain.Decoration = false
	end
end

-- [[ 2. CORE OBJECT PROCESSOR ]] --
local function ProcessObject(obj)
	-- Remove Textures
	if obj:IsA("Decal") or obj:IsA("Texture") or obj:IsA("SurfaceAppearance") then
		obj:Destroy()

	-- Remove Particles & Emitters
	elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") then
		obj:Destroy()

	-- Optimize BaseParts (Parts, MeshParts, Truss, etc.)
	elseif obj:IsA("BasePart") and not obj:IsA("Terrain") then
		obj.Material = Enum.Material.SmoothPlastic
		obj.Reflectance = 0
		obj.CastShadow = false

		-- If it's a MeshPart, clear its baked texture ID
		if obj:IsA("MeshPart") then
			obj.TextureID = ""
		end

	-- Remove any rogue camera effects
	elseif obj:IsA("PostEffect") then
		obj:Destroy()
	end
end

-- [[ 3. SLOW REMOVAL LOOP ]] --
local function ProcessExistingObjects()
	local descendants = Workspace:GetDescendants()
	local count = 0

	for _, obj in ipairs(descendants) do
		ProcessObject(obj)
		count += 1

		-- Yield to prevent freezing the client
		if count >= BATCH_SIZE then
			count = 0
			task.wait(YIELD_TIME)
		end
	end
end

-- [[ EXECUTION ]] --

-- Step 1: Nuke the lighting immediately (this doesn't cause lag)
OptimizeLightingAndTerrain()

-- Step 2: Begin the slow removal of existing Workspace objects on a separate thread
task.spawn(ProcessExistingObjects)

-- Step 3: Listen for any new objects added to the game and strip them instantly
Workspace.DescendantAdded:Connect(function(obj)
	ProcessObject(obj)
end)

-- Optional Step 4: Ensure no scripts try to force new lighting effects
Lighting.ChildAdded:Connect(function(obj)
	if obj:IsA("PostEffect") or obj:IsA("Atmosphere") or obj:IsA("Sky") or obj:IsA("Clouds") then
		task.wait() -- Wait one frame to ensure properties are loaded, then destroy
		obj:Destroy()
	end
end)
